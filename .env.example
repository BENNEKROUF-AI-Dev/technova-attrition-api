# ─────────────────────────────────────────────────────────
#  Exemple de configuration — À COPIER en `.env` (non versionné)
#  cp .env.example .env  puis renseignez vos vraies valeurs
# ─────────────────────────────────────────────────────────

# Environnement applicatif : dev | test | prod
APP_ENV=dev

# ── API ──────────────────────────────────────────────────
API_TITLE="TechNova Attrition API"
API_VERSION="0.1.0"

# ── Authentification (JWT) ───────────────────────────────
# Générez une clé robuste, ex : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez-moi-en-une-cle-aleatoire-robuste
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ── Base de données PostgreSQL ───────────────────────────
POSTGRES_USER=technova
POSTGRES_PASSWORD=changez-moi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=attrition
# URL complète (utilisée par SQLAlchemy)
DATABASE_URL=postgresql+psycopg2://technova:changez-moi@localhost:5432/attrition

# ── Modèle ───────────────────────────────────────────────
MODEL_PATH=models/attrition_model.joblib
